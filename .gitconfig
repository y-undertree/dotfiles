[user]
name  = undertree
email = sample@gmail.com

[core]
excludesfile = ~/.gitignore
autocrlf = false

[color]
ui = auto

[alias]
st = status
sh = show
sb = show-branch
rema = rebase origin/master master
ci = commit
cmt = commit -v
coma = commit -a -v
cma = commit -a -v
co = checkout
cl = clone
dc = diff --cached
df = diff
d = diff -C
ds = diff -C --stat
dsp = diff -C --stat -p
dw = diff -C --color-words
lg = log --graph --all --color --pretty='%x09%h %cn%x09%s %Cred%d'
l = log
m = checkout master
ituja = log --patch -S

